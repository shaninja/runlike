{
  "cleanup": [
    {
      "command": [
        "docker",
        "network",
        "rm",
        "runlike-probe-{probe_id}-net"
      ]
    }
  ],
  "command": [
    "sh",
    "-c",
    "sleep 600"
  ],
  "docker_run_args": [
    "--network",
    "runlike-probe-{probe_id}-net",
    "--ip",
    "172.28.5.10"
  ],
  "id": "p0-ip",
  "image": "busybox",
  "option_id": "ip",
  "setup": [
    {
      "command": [
        "docker",
        "network",
        "create",
        "--subnet",
        "172.28.5.0/24",
        "runlike-probe-{probe_id}-net"
      ]
    }
  ]
}
