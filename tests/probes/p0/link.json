{
  "cleanup": [
    {
      "command": [
        "docker",
        "container",
        "rm",
        "-f",
        "runlike-probe-{probe_id}-target"
      ]
    }
  ],
  "command": [
    "sh",
    "-c",
    "sleep 600"
  ],
  "docker_run_args": [
    "--link",
    "runlike-probe-{probe_id}-target:linked"
  ],
  "id": "p0-link",
  "image": "busybox",
  "option_id": "link",
  "setup": [
    {
      "command": [
        "docker",
        "container",
        "create",
        "--name",
        "runlike-probe-{probe_id}-target",
        "busybox",
        "sh",
        "-c",
        "sleep 600"
      ]
    }
  ]
}
