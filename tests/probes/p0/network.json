{
  "cleanup": [
    {
      "command": [
        "docker",
        "network",
        "rm",
        "runlike-probe-{probe_id}-net"
      ]
    }
  ],
  "command": [
    "sh",
    "-c",
    "sleep 600"
  ],
  "docker_run_args": [
    "--network",
    "runlike-probe-{probe_id}-net"
  ],
  "id": "p0-network",
  "image": "busybox",
  "option_id": "network",
  "setup": [
    {
      "command": [
        "docker",
        "network",
        "create",
        "runlike-probe-{probe_id}-net"
      ]
    }
  ]
}
